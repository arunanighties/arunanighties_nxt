{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "node --env-file=../../.env -e \"import('child_process').then(cp => cp.execSync('npx drizzle-kit push --config ./drizzle.config.cjs', {stdio: 'inherit'}))\"",
    "push-force": "node --env-file=../../.env -e \"import('child_process').then(cp => cp.execSync('npx drizzle-kit push --force --config ./drizzle.config.cjs', {stdio: 'inherit'}))\""
  },
  "dependencies": {
    "mysql2": "^3.12.0",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.9"
  }
}
